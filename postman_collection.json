            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.id) {",
                  "        pm.collectionVariables.set('my_user_id', jsonData.id.toString());",
                  "        console.log('✅ User ID saved:', jsonData.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
